# Variables de entorno requeridas

# URL base para llamadas a API
# - Desarrollo local: http://localhost:3000
# - Vercel: https://tu-proyecto.vercel.app
NEXT_PUBLIC_API_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb+srv://usuario:contraseña@cluster.mongodb.net/database

# JWT Secret para tokens de autenticación
JWT_SECRET=tu-secret-key-super-segura

# Variables de producción en Vercel
# Asegúrate de definir NEXT_PUBLIC_API_URL en los settings de Vercel
